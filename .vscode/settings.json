{
  // Evita o Code Runner criar tempCodeRunnerFile.* ao rodar "seleção".
  // Ele vai sempre rodar o arquivo inteiro.
  "code-runner.ignoreSelection": true,

  // Qualidade de vida (não é obrigatório, mas ajuda).
  "code-runner.saveFileBeforeRun": true,
  "code-runner.fileDirectoryAsCwd": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.runInTerminal": true,

  // Faz o "Run Code" do Code Runner rodar com segurança (mata Operators.exe pendente).
  // Isso evita o erro MSB3027/MSB3021 de arquivo em uso.
  "code-runner.executorMap": {
    "csharp": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\.vscode\\run-operators.ps1\""
  },

  // Evita "organizar imports"/"fix all" mexer em usings no C# ao salvar.
  "[csharp]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never",
      "source.fixAll": "never"
    }
  },

  // Reduz chance de aceitar sugestão acidental no Enter (onde pode entrar um `using ...;`).
  "editor.acceptSuggestionOnEnter": "off"
}
